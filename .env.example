# Configuration Contact Mailer
# Copier ce fichier en .env et adapter les valeurs

# Clé secrète pour les sessions (générer avec: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-in-production

# Identifiants admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Base de données (par défaut SQLite dans data/contacts.db)
# DATABASE_URL=sqlite:///data/contacts.db

# === CONFIGURATION SMTP ===
# Serveur SMTP (ex: mail.infomaniak.com, smtp.gmail.com)
SMTP_HOST=mail.infomaniak.com
SMTP_PORT=587

# Identifiants SMTP
SMTP_USER=votre@email.com
SMTP_PASSWORD=votre_mot_de_passe

# Expéditeur
SMTP_SENDER_EMAIL=votre@email.com
SMTP_SENDER_NAME=Votre Nom

# TLS (true pour port 587, false pour port 465 SSL)
SMTP_USE_TLS=true

# Rate limiting : nombre d'emails par minute (défaut: 20)
# Ajuster selon les limites de votre fournisseur
MAIL_RATE_PER_MINUTE=20

# URL publique de l'application (pour les liens de désabonnement)
BASE_URL=https://votre-domaine.com

# Identifiant technique de l'instance (PWA : icône, initiales, manifest)
# INSTANCE_COLOR : couleur hex, ex: #e74c3c (rouge), #16a34a (vert), #f59e0b (jaune)
INSTANCE_NAME=
INSTANCE_COLOR=#2563eb
# Nom d'affichage UI (navbar + page de connexion). Si vide, INSTANCE_NAME est utilisé.
DISPLAY_NAME=

# === BOOKSTACK API ===
# URL de l'instance BookStack (ex: https://docs.example.com)
BOOKSTACK_URL=
# Token API (créé dans BookStack > Profil > API Tokens)
BOOKSTACK_TOKEN_ID=
BOOKSTACK_TOKEN_SECRET=

# === SEAFILE API ===
# URL de l'instance Seafile (ex: https://drive.example.com)
SEAFILE_URL=
# Token API (créé via un compte admin Seafile, ou Avatar > Paramètres > Mes tokens API)
SEAFILE_TOKEN=

# === BOUNCES (boîte IMAP dédiée au Return-Path) ===
# Créer une boîte dédiée sur votre hébergeur (ex: lfll-bounce@asso34.fr)
# et la renseigner ici. Chaque instance doit avoir sa propre boîte bounce.
BOUNCE_IMAP_HOST=
BOUNCE_IMAP_PORT=993
BOUNCE_IMAP_USER=lfll-bounce@asso34.fr
BOUNCE_IMAP_PASSWORD=
# Dossier surveillé (défaut: INBOX)
BOUNCE_IMAP_FOLDER=INBOX
# Dossier de destination des bounces traités (créé automatiquement)
BOUNCE_IMAP_PROCESSED_FOLDER=Traite
# Adresse Return-Path injectée dans les mailings (= BOUNCE_IMAP_USER si non défini)
BOUNCE_RETURN_PATH=

# === DEMANDES DE DIFFUSION (boîte IMAP dédiée) ===
# Adresse à laquelle les contacts peuvent écrire pour demander une diffusion
# (ex: demande-diffusion@votre-domaine.com)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
# Dossier surveillé pour les nouvelles demandes (défaut: INBOX)
IMAP_FOLDER=INBOX
# Dossier de destination des demandes traitées (créé automatiquement)
IMAP_PROCESSED_FOLDER=Traite
# Filtre optionnel : ne traiter que les messages dont le sujet contient cette
# chaîne (ex: "mailing:"). Laisser vide pour traiter tous les messages du dossier.
IMAP_SUBJECT_FILTER=
# Filtre optionnel : ne traiter que les messages adressés à cet alias
# (ex: "diffusion@domaine.fr"). Utile si la boîte reçoit plusieurs alias.
# Laisser vide pour traiter tous les messages du dossier.
IMAP_TO_FILTER=
